<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0D1117">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#161B22" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="💳 VF Cash Monitor"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvCount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="0 عملية"
            android:textColor="#58A6FF" android:textSize="12sp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">

            <!-- Status + Toggle -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/card" android:orientation="vertical"
                android:padding="14dp" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="تفعيل الخدمة"
                        android:textColor="#C9D1D9" android:textSize="15sp" android:textStyle="bold"/>
                    <Switch android:id="@+id/swOn" android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <TextView android:id="@+id/tvStatus" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="..."
                    android:textColor="#8B949E" android:textSize="11sp"
                    android:fontFamily="monospace" android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <!-- Settings -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/card" android:orientation="vertical"
                android:padding="14dp" android:layout_marginBottom="10dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="⚙️ الإعدادات" android:textColor="#C9D1D9"
                    android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="رابط API" android:textColor="#8B949E" android:textSize="11sp" android:layout_marginBottom="3dp"/>
                <EditText android:id="@+id/etUrl" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/input" android:inputType="textUri"
                    android:hint="https://smmrace.space/apivfcash.php" android:hintTextColor="#484F58"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:singleLine="true"
                    android:textColor="#C9D1D9" android:textSize="12sp" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Token السري" android:textColor="#8B949E" android:textSize="11sp" android:layout_marginBottom="3dp"/>
                <EditText android:id="@+id/etToken" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/input" android:inputType="textPassword"
                    android:hint="من قاعدة البيانات جدول vf_settings" android:hintTextColor="#484F58"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:singleLine="true"
                    android:textColor="#C9D1D9" android:textSize="12sp" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="رقم فودافون كاش (المُرسِل)" android:textColor="#8B949E" android:textSize="11sp" android:layout_marginBottom="3dp"/>
                <EditText android:id="@+id/etPhone" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/input" android:inputType="phone"
                    android:text="01107122194" android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:singleLine="true" android:textColor="#C9D1D9" android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <Button android:id="@+id/btnSave" android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:layout_marginEnd="8dp"
                        android:background="@drawable/btn_green" android:text="💾 حفظ"
                        android:textColor="#FFF" android:textSize="13sp"/>
                    <Button android:id="@+id/btnTest" android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:background="@drawable/btn_blue"
                        android:text="🔗 اختبار" android:textColor="#FFF" android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Log header -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="📋 آخر العمليات" android:textColor="#C9D1D9"
                android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Logs -->
    <ListView android:id="@+id/lvLogs" android:layout_width="match_parent"
        android:layout_height="190dp" android:background="#161B22"
        android:divider="#21262D" android:dividerHeight="1dp"
        android:padding="8dp"/>

</LinearLayout>
